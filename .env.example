# Firebase Config — copy this file to .env and fill in your values
# Get these from: Firebase Console > Project Settings > Your apps > Web app

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Weather (OpenWeatherMap — free at openweathermap.org)
VITE_OPENWEATHER_API_KEY=your-openweathermap-api-key
VITE_WEATHER_CITY=Dallas

# Email OAuth
# Google OAuth client for standalone Gmail account connections (multiple Google accounts)
VITE_GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id

# Microsoft Entra app for Exchange Online / Graph mail
VITE_MICROSOFT_CLIENT_ID=your-microsoft-client-id
VITE_MICROSOFT_TENANT_ID=common
